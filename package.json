{
  "name": "essaim",
  "version": "0.1.1",
  "description": "Spawn N coordinated Claude Code agents — orchestrator + behavior catalog. Pairs with @swoofer/promptweave + mcp-coordinator.",
  "type": "module",
  "license": "MIT",
  "author": "Maxime Gagnon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swoofer/essaim.git"
  },
  "homepage": "https://swoofer.github.io/essaim",
  "bugs": {
    "url": "https://github.com/swoofer/essaim/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "agents",
    "orchestrator",
    "multi-agent",
    "coordination",
    "mcp",
    "anthropic",
    "behaviors",
    "yaml"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./types": {
      "types": "./dist/src/orchestrator/types.d.ts",
      "default": "./dist/src/orchestrator/types.js"
    }
  },
  "bin": {
    "essaim": "./dist/cli/index.js"
  },
  "files": [
    "dist/src/",
    "dist/cli/",
    "behaviors/",
    "presets/",
    "compositions/",
    "scripts/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx cli/index.ts",
    "dev": "tsx cli/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@swoofer/promptweave": "^0.1.0",
    "mcp-coordinator": "^0.1.0",
    "commander": "^14.0.3",
    "handlebars": "^4.7.0",
    "mqtt": "^5.15.0",
    "pino": "^10.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "ip-address": "^10.2.0"
  }
}
